// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  User
  Creator
}

model User {
  id            String @id @default(uuid())
  firstName     String
  lastName      String
  email         String @unique
  password      String
  contactNumber BigInt

  role                     Role     @default(User) // enum: ["Student", "Admin", "Instructor"],

  image                    String?
  resetPasswordToken       String?
  resetPasswordTokenExpiry DateTime?
  refreshToken             String?
  refreshTokenExpiry       DateTime?
  createdAt                DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  blogs   Blog[] //refer to  blog model 
  comment Comment[]
  profile Profile? @relation("UserProfile") // provided a name to relation issey nested query likhne mai easy hota hai.
}


// Profile.userId = User.id  prisma will automatically now do this.
model Profile {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation("UserProfile",fields: [userId], references: [id], onDelete: Cascade)
  gender        String?
  dateOfBirth   String?
  about         String?
  contactNumber BigInt?
  avatar        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Blog {
  id        String  @id @default(uuid())
  title     String
  content   String
  published Boolean? @default(false)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  coverImageUrl String? // to upload on cloudinary.. optional

  comments Comment[] // 1 - n

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published]) // if want to search on the basis of publisehed hai ki nhi .
  @@index([userId])
}

//  blog se relation 
// user se relation 

model Comment {
  id String @id @default(uuid())

  // what user commented.
  content String

  userId String
  blogId String

  //user and blog
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  blog Blog @relation(fields: [blogId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // adding index.
  @@index([userId])
  @@index([blogId])
}

